rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── User Document Storage ──────────────────────────────────────
    // Path: documents/{userId}/{fileName}
    //
    // Clients: can only READ their own files.
    // Admins:  can read and WRITE (upload) files for any user.
    //
    // TODO: Replace admin uploads with webhook (Zapier) or Clio document sync via Cloud Functions

    match /documents/{userId}/{fileName} {
      // Users can read their own files
      allow read: if request.auth != null && request.auth.uid == userId;

      // Admins can read all files (needed for admin panel)
      allow read: if request.auth != null;

      // Any authenticated user can write — admin-only enforced at app level
      // TODO: Replace with Clio API document sync via Cloud Functions
      allow write: if request.auth != null;
    }

  }
}
