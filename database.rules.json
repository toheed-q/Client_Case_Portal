{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "cases": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$caseId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
